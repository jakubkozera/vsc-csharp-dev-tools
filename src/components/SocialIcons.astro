---
/**
 * Custom SocialIcons override — default Starlight social links + Install dropdown.
 */
import Default from '@astrojs/starlight/components/SocialIcons.astro';
---

<div class="header-actions">
  <Default />
  <div class="install-dropdown">
    <button class="install-btn" aria-haspopup="true" aria-expanded="false">
      Install
      <svg class="chevron" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </button>
    <ul class="install-menu" role="menu">
      <li role="none">
        <a
          href="https://marketplace.visualstudio.com/items?itemName=JakubKozera.csharp-dev-tools"
          target="_blank"
          rel="noopener"
          role="menuitem"
          class="install-option"
        >
          VS Code Marketplace
        </a>
      </li>
      <li role="none">
        <a
          href="https://open-vsx.org/extension/JakubKozera/csharp-dev-tools"
          target="_blank"
          rel="noopener"
          role="menuitem"
          class="install-option"
        >
          Open VSX Registry
        </a>
      </li>
    </ul>
  </div>
</div>

<script is:inline>
  // Dropdown toggle logic
  function initInstallDropdown() {
    document.querySelectorAll('.install-dropdown').forEach(function(dropdown) {
      var btn = dropdown.querySelector('.install-btn');
      var menu = dropdown.querySelector('.install-menu');
      if (!btn || !menu) return;
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';

      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        menu.classList.toggle('open', !open);
      });

      document.addEventListener('click', function() {
        btn.setAttribute('aria-expanded', 'false');
        menu.classList.remove('open');
      });

      menu.addEventListener('click', function(e) { e.stopPropagation(); });
    });
  }
  initInstallDropdown();
  document.addEventListener('astro:after-swap', initInstallDropdown);
</script>

<style>
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ---- Install button ---- */
  .install-dropdown {
    position: relative;
  }

  .install-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sl-color-text-invert, #0b0d0e);
    background: var(--sl-color-accent);
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: background 150ms ease, transform 150ms ease;
    white-space: nowrap;
  }

  .install-btn:hover {
    background: var(--sl-color-accent-high, #99f6e4);
    transform: translateY(-1px);
  }

  .chevron {
    width: 12px;
    height: 12px;
    transition: transform 200ms ease;
  }

  .install-btn[aria-expanded='true'] .chevron {
    transform: rotate(180deg);
  }

  /* ---- Dropdown menu ---- */
  .install-menu {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 210px;
    list-style: none;
    margin: 0;
    padding: 0.35rem 0;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    z-index: 100;
  }

  .install-menu.open {
    display: block;
  }

  .install-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.9rem;
    font-size: 0.875rem;
    color: var(--sl-color-text);
    text-decoration: none;
    transition: background 120ms ease, color 120ms ease;
    border: none;
  }

  .install-option:hover {
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-text-accent);
  }

  @media (max-width: 50rem) {
    .install-dropdown {
      display: none;
    }
  }
</style>
